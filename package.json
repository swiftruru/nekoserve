{
  "name": "nekoserve",
  "version": "0.2.0",
  "description": "🐱 Cat café queuing & service simulation desktop app — Electron + React + SimPy",
  "main": "out/main/index.js",
  "author": "NekoServe",
  "license": "MIT",
  "scripts": {
    "dev": "env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "dev:simulator": "cd simulator-python && python -m simulator",
    "build:renderer": "electron-vite build --outDir out/renderer --config electron.vite.config.ts",
    "build:desktop": "electron-vite build",
    "build:simulator:unix": "bash scripts/build-simulator.sh",
    "build:simulator:win": "powershell -ExecutionPolicy Bypass -File scripts/build-simulator.ps1",
    "build:simulator": "node scripts/build-simulator.js",
    "ci:build": "electron-vite build",
    "ci:pack:mac": "electron-builder --mac --config electron-builder.yml",
    "ci:pack:win": "electron-builder --win --config electron-builder.yml",
    "ci:pack:linux": "electron-builder --linux --config electron-builder.yml",
    "pack": "electron-builder --config electron-builder.yml",
    "pack:mac": "electron-builder --mac --config electron-builder.yml",
    "pack:win": "electron-builder --win --config electron-builder.yml",
    "pack:linux": "electron-builder --linux --config electron-builder.yml",
    "test:simulator": "cd simulator-python && python -m pytest tests/ -v",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "postinstall": "electron-builder install-app-deps && node scripts/rename-electron-app.js"
  },
  "dependencies": {
    "i18next": "^23.16.8",
    "react-i18next": "^14.1.3",
    "recharts": "^2.12.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "electron": "^33.4.11",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.1.0",
    "postcss": "^8.4.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3"
  }
}
